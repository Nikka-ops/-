# InterviewRadar environment (optional)
# Copy to .env and adjust, or export in your shell.

# Where runtime outputs go (banks, handoff, uploads). Default: ./corpus_cache
# INTERVIEWRADAR_CACHE_DIR=corpus_cache

# MediaCrawler install path for Xiaohongshu live scrape. Default: ~/.mediacrawler
# MEDIACRAWLER_HOME=~/.mediacrawler

# Override demo corpus path (default: examples/sample_raw_posts.json in repo)
# INTERVIEWRADAR_SAMPLE_POSTS=examples/sample_raw_posts.json

# Boss直聘 Cookie（浏览器登录 zhipin.com 后从 Network 复制 Cookie 整行）
# 配置步骤: docs/setup/boss-zhipin-cookie.md
# 或运行: bash scripts/tools/setup-boss-cookie.sh
# BOSS_ZHIPIN_COOKIE=lastCity=101010100; wt2=...; __zp_stoken__=...

# Boss CDP（无需 Cookie，见 docs/setup/boss-zhipin-cookie.md 方式三）
# BOSS_CDP_PORT=9222
# BOSS_CDP=1

# DeepSeek — 规则拿不准的帖子 AI 复核（POST_AI_FILTER=1 且已配置 KEY 时启用）
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# POST_AI_FILTER=1
# POST_AI_FILTER_MAX_CHARS=900
