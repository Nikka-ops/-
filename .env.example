# InterviewRadar environment (optional)
# Copy to .env and adjust, or export in your shell.

# Where runtime outputs go (banks, handoff, uploads). Default: ./corpus_cache
# INTERVIEWRADAR_CACHE_DIR=corpus_cache

# Xiaohongshu — Spider_XHS (see docs/setup/spider_xhs.md)
# 长期增量（默认 24 词/次；核心词全扫见 xhs_incremental --core-only）:
# XHS_DAILY_KEYWORDS_PER_DAY=24
# XHS_MAX_KEYWORDS_PER_RUN=32
# XHS_BATCH_PAUSE_SECONDS=30
# Full cookie string from DevTools, or use CDP Chrome (default):
# XHS_COOKIES=web_session=...; a1=...; webId=...
# XHS_WEB_SESSION=...   # fallback: web_session only

# Spider_XHS install path. Default: ~/.spider_xhs
# SPIDER_XHS_HOME=~/.spider_xhs
# XHS_CDP=1
# XHS_CDP_PORT=9233

# Override demo corpus path (default: examples/sample_raw_posts.json in repo)
# INTERVIEWRADAR_SAMPLE_POSTS=examples/sample_raw_posts.json

# Boss直聘 Cookie（浏览器登录 zhipin.com 后从 Network 复制 Cookie 整行）
# 配置步骤: docs/setup/boss-zhipin-cookie.md
# 或运行: bash scripts/tools/setup-boss-cookie.sh
# BOSS_ZHIPIN_COOKIE=lastCity=101010100; wt2=...; __zp_stoken__=...

# Boss CDP（无需 Cookie，见 docs/setup/boss-zhipin-cookie.md 方式三）
# BOSS_CDP_PORT=9222
# BOSS_CDP=1

# DeepSeek — 面经/题库筛选均走 Agent（配置 KEY 后默认启用；无 KEY 时仅极简离线兜底）
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# POST_AI_FILTER=1
# POST_AI_FILTER_MAX_CHARS=900

# 视觉大模型（可选）— OCR 失败/低质图片帖用 VL 模型读图
# 任意 OpenAI 兼容端点：通义 Qwen-VL / GLM-4V 等
VISION_API_KEY=
VISION_API_BASE=https://dashscope.aliyuncs.com/compatible-mode
VISION_MODEL=qwen-vl-plus
